{
  "name": "modempic-wellness",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env -e .env.local -- prisma migrate deploy",
    "db:seed": "dotenv -e .env -e .env.local -- npx tsx prisma/seed.ts",
    "import:noofox": "npx tsx scripts/import-noofox-products.ts",
    "import:noofox-blog": "dotenv -e .env -e .env.local -- npx tsx scripts/import-noofox-blog.ts",
    "import:noofox-users-orders": "npx tsx scripts/import-noofox-users-orders.ts",
    "import:noofox-users-orders:apply": "npx tsx scripts/import-noofox-users-orders.ts --apply",
    "organize:noofox-product-images": "npx tsx scripts/organize-noofox-product-images.ts",
    "sync:noofox-main-images": "npx tsx scripts/sync-noofox-main-images.ts",
    "db:studio": "dotenv -e .env -e .env.local -- prisma studio",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/react": "^3.0.170",
    "@auth/prisma-adapter": "^2.7.2",
    "@prisma/client": "6.6.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@react-email/components": "^0.0.32",
    "ai": "^6.0.168",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.503.0",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.25",
    "next-mdx-remote": "^5.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^2.15.0",
    "resend": "^4.0.0",
    "sanitize-html": "^2.17.3",
    "tailwind-merge": "^2.5.0",
    "turndown": "^7.2.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "csv-parse": "^5.6.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "prisma": "6.6.0",
    "sharp": "^0.34.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
