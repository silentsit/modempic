{
  "name": "modempic-wellness",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "scripts": {
    "images:placeholders": "tsx scripts/generate-product-image-placeholders.ts",
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "dotenv -e .env -e .env.local -- prisma migrate deploy && dotenv -e .env -e .env.local -- next build",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env -e .env.local -- prisma migrate deploy",
    "db:validate": "dotenv -e .env -e .env.local -- prisma validate",
    "db:seed": "dotenv -e .env -e .env.local -- npx tsx prisma/seed.ts",
    "import:noofox": "npx tsx scripts/legacy-migration/import-noofox-products.ts",
    "import:noofox:cloudinary": "dotenv -e .env -e .env.local -- npx tsx scripts/legacy-migration/import-noofox-products.ts --apply --cloudinary",
    "migrate:product-images:cloudinary": "dotenv -e .env -e .env.local -- npx tsx scripts/migrate-product-images-to-cloudinary.ts",
    "migrate:product-images:cloudinary:apply": "dotenv -e .env -e .env.local -- npx tsx scripts/migrate-product-images-to-cloudinary.ts --apply",
    "import:noofox-blog": "dotenv -e .env -e .env.local -- npx tsx scripts/legacy-migration/import-noofox-blog.ts",
    "import:noofox-users-orders": "npx tsx scripts/legacy-migration/import-noofox-users-orders.ts",
    "import:noofox-users-orders:apply": "npx tsx scripts/legacy-migration/import-noofox-users-orders.ts --apply",
    "import:woo-reviews": "dotenv -e .env -e .env.local -- npx tsx scripts/legacy-migration/import-woo-reviews.ts",
    "import:woo-reviews:apply": "dotenv -e .env -e .env.local -- npx tsx scripts/legacy-migration/import-woo-reviews.ts --apply",
    "organize:noofox-product-images": "npx tsx scripts/legacy-migration/organize-noofox-product-images.ts",
    "sync:noofox-main-images": "npx tsx scripts/legacy-migration/sync-noofox-main-images.ts",
    "db:studio": "dotenv -e .env -e .env.local -- prisma studio",
    "admin:create": "dotenv -e .env -e .env.local -- npx tsx scripts/create-admin-user.ts",
    "passwords:set-missing": "dotenv -e .env -e .env.local -- npx tsx scripts/set-missing-passwords.ts",
    "passwords:set-missing:apply": "dotenv -e .env -e .env.local -- npx tsx scripts/set-missing-passwords.ts --apply",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/react": "^3.0.170",
    "@auth/prisma-adapter": "^2.7.2",
    "@prisma/client": "6.6.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "ai": "^6.0.168",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.503.0",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.25",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-email": "^6.1.1",
    "recharts": "^2.15.0",
    "resend": "^4.0.0",
    "sanitize-html": "^2.17.3",
    "tailwind-merge": "^2.5.0",
    "turndown": "^7.2.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "cloudinary": "^2.10.0",
    "csv-parse": "^5.6.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "prisma": "6.6.0",
    "sharp": "^0.34.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
