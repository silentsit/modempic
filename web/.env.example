# Copy to .env.local and fill in.
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
# Optional — only if you use Neon pooler + separate direct connection for migrations (see prisma/schema.prisma).
# DIRECT_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
AUTH_SECRET="replace-with-32+chars-random"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""
RESEND_API_KEY=""
EMAIL_FROM="orders@yourdomain.com"
# Optional: receive a copy of each new customer order (HTML template; staff inbox).
ADMIN_ORDER_NOTIFICATION_EMAIL=""
CRON_SECRET=""
DEV_PAYMENT_SIMULATE="1"
CRYPTO_WEBHOOK_SECRET="replace-for-webhook-hmac"
GUARDARIAN_API_KEY=""
GUARDARIAN_MODE="sandbox"

# --- Crypto checkout: BTCPay (preferred) or Paymento
# BTCPay — non-custodial Bitcoin / Lightning: https://docs.btcpayserver.org/Development/ecommerce-integration-guide/
# BTCPAY_URL="https://pay.yourdomain.com"
# BTCPAY_API_KEY=""
# BTCPAY_STORE_ID=""
# BTCPAY_WEBHOOK_SECRET=""
# NEXT_PUBLIC_BTCPAY_URL="https://pay.yourdomain.com"
# CRYPTO_PROVIDER="btcpay"
# Webhook URL in BTCPay: https://yourdomain.com/api/webhooks/btcpay

# Paymento — multi-asset crypto gateway: https://docs.paymento.io
# PAYMENTO_API_KEY=""
# PAYMENTO_SECRET_KEY=""
# PAYMENTO_SPEED="1"
# Webhook URL in Paymento: https://yourdomain.com/api/webhooks/paymento
SEED_ADMIN_PASSWORD="ModempicDev2025!"
# Optional: non-interactive admin bootstrap (prefer `npm run admin:create` and type the password).
# ADMIN_PASSWORD=""

# Optional: storefront science/safety chat (OpenAI). Without this, the chat shows a configuration error.
OPENAI_API_KEY=""
# Optional: OpenAI chat model id for @ai-sdk/openai (default: gpt-4o-mini). Examples: gpt-4o-mini, gpt-4o, gpt-4.1-mini
OPENAI_CHAT_MODEL="gpt-4o-mini"
# Legacy alias for the same setting (optional; ignored if OPENAI_CHAT_MODEL is set)
CHAT_OPENAI_MODEL=""

# --- Cloudinary (product images)
# Full re-import from Noofox + Cloudinary upload:
#   npm run import:noofox:cloudinary
# Migrate existing DB rows that still use /imported-products/… (reads files under web/public; run `npm run prebuild` first if needed):
#   npm run migrate:product-images:cloudinary          # dry-run
#   npm run migrate:product-images:cloudinary:apply   # upload + DB update
# Prefer a single URL from the Cloudinary dashboard:
# CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"
# Or set the three variables:
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
# Optional upload prefix (default: modempic/products)
# CLOUDINARY_UPLOAD_FOLDER="modempic/products"
# Storefront only needs image URLs in the database; Cloudinary env vars are not required at runtime unless you upload from the app.

# --- Social proof (admin: /admin/social-proof). Legacy env flags still work as fallback.
# NEXT_PUBLIC_SOCIAL_PROOF_ENABLED="1"
# Optional: comma-separated path prefixes allowed, or "*" for all routes (default = home, shop, product only).
# NEXT_PUBLIC_SOCIAL_PROOF_PATHS="/,/shop,/product"
# NEXT_PUBLIC_SOCIAL_PROOF_AGGREGATE="1"
# Footer label in the toast (default Modempic).
# NEXT_PUBLIC_SOCIAL_PROOF_BRAND_LABEL="Modempic"
# SOCIAL_PROOF_WINDOW_DAYS="7"
# Demo fallback when there are no recent COMPLETED orders (message-only rows still work; structured is clearer):
# SOCIAL_PROOF_DEMO_JSON='[{"message":"Alex from Phoenix, AZ just completed an order","completedAtIso":"2026-05-01T18:00:00.000Z","displayName":"Alex","actionLine":"Just completed an order.","locationLine":"Phoenix, AZ"}]'
